# Varsayılan akış: tarayıcı Web Speech API (ücretsiz, kurulum yok).
# Sadece /voice ile sunucu tarafı STT istiyorsan aşağıyı doldur.

# Seçenek A: OpenAI Whisper API (ücretli)
# OPENAI_API_KEY=sk-...
# WHISPER_MODEL=whisper-1

# Seçenek B: yerel faster-whisper (ücretsiz, çevrimdışı)
#   pip install faster-whisper
# LOCAL_WHISPER_MODEL=small   # tiny | base | small | medium

DB_URL=sqlite:///./data/vitalog.db
